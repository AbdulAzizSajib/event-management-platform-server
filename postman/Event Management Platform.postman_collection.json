							"raw": "{{apiUrl}}/payments/my-payments?page=1&limit=10",
							"host": ["{{apiUrl}}"],
							"path": ["payments", "my-payments"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						},
						"description": "Requires authentication. Get all your payment records."
					}
				},
				{
					"name": "Get Event Payments (Organizer)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiUrl}}/payments/event/:eventId?page=1&limit=10",
							"host": ["{{apiUrl}}"],
							"path": ["payments", "event", ":eventId"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							],
							"variable": [
								{ "key": "eventId", "value": "" }
							]
						},
						"description": "Only event organizer can view. Get all payments for a specific event."
					}
				}
			]
		},
		{
			"name": "Events",
			"item": [
				{
					"name": "Create Event",
					"request": {
						"method": "POST",
