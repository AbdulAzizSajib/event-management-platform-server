		{
			"name": "Participants",
			"item": [
				{
					"name": "Join Event",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"eventId\": \"paste-event-id-here\"\n}"
						},
						"url": {
							"raw": "{{apiUrl}}/participants/join",
							"host": ["{{apiUrl}}"],
							"path": ["participants", "join"]
						},
						"description": "Requires authentication. Free PUBLIC events auto-approve, others stay PENDING."
					}
				},
				{
					"name": "Get My Participations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiUrl}}/participants/my-participations?page=1&limit=10",
							"host": ["{{apiUrl}}"],
							"path": ["participants", "my-participations"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" },
								{ "key": "status", "value": "APPROVED", "disabled": true }
							]
						},
						"description": "Requires authentication. Optional filter by status: PENDING, APPROVED, REJECTED, BANNED."
					}
				},
				{
					"name": "Get Event Participants",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiUrl}}/participants/event/:eventId?page=1&limit=10",
							"host": ["{{apiUrl}}"],
							"path": ["participants", "event", ":eventId"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" },
								{ "key": "status", "value": "PENDING", "disabled": true }
							],
							"variable": [
								{ "key": "eventId", "value": "" }
							]
						},
						"description": "Requires authentication. Get all participants for a specific event."
					}
				},
				{
					"name": "Approve Participant",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"APPROVED\"\n}"
						},
						"url": {
							"raw": "{{apiUrl}}/participants/:participantId/status",
							"host": ["{{apiUrl}}"],
							"path": ["participants", ":participantId", "status"],
							"variable": [
								{ "key": "participantId", "value": "" }
							]
						},
						"description": "Only event organizer can approve. Sets participant status to APPROVED."
					}
				},
				{
					"name": "Reject Participant",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"REJECTED\"\n}"
						},
						"url": {
							"raw": "{{apiUrl}}/participants/:participantId/status",
							"host": ["{{apiUrl}}"],
							"path": ["participants", ":participantId", "status"],
							"variable": [
								{ "key": "participantId", "value": "" }
							]
						},
						"description": "Only event organizer can reject."
					}
				},
				{
					"name": "Ban Participant",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"BANNED\"\n}"
						},
						"url": {
							"raw": "{{apiUrl}}/participants/:participantId/status",
							"host": ["{{apiUrl}}"],
							"path": ["participants", ":participantId", "status"],
							"variable": [
								{ "key": "participantId", "value": "" }
							]
						},
						"description": "Only event organizer can ban. Banned users cannot rejoin."
					}
				},
				{
					"name": "Cancel Participation",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{apiUrl}}/participants/cancel/:eventId",
							"host": ["{{apiUrl}}"],
							"path": ["participants", "cancel", ":eventId"],
							"variable": [
								{ "key": "eventId", "value": "" }
							]
						},
						"description": "Requires authentication. Cancel your own participation (cannot cancel if banned)."
					}
				}
			]
		},
