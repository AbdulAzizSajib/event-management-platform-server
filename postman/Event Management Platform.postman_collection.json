						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Tech Meetup Dhaka 2026\",\n  \"description\": \"A community meetup for developers in Dhaka to share knowledge and network.\",\n  \"date\": \"2026-04-15T00:00:00.000Z\",\n  \"time\": \"10:00 AM\",\n  \"venue\": \"Dhaka IT Park, Karwan Bazar\",\n  \"type\": \"PUBLIC\",\n  \"fee\": 0\n}"
						},
						"url": {
							"raw": "{{apiUrl}}/events",
							"host": ["{{apiUrl}}"],
							"path": ["events"]
						},
						"description": "Requires authentication. Creates an event with the logged-in user as organizer."
					}
				},
				{
					"name": "Create Paid Private Event",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Exclusive Workshop on System Design\",\n  \"description\": \"An intensive hands-on workshop covering system design fundamentals and advanced patterns.\",\n  \"date\": \"2026-05-01T00:00:00.000Z\",\n  \"time\": \"02:00 PM\",\n  \"eventLink\": \"https://meet.google.com/abc-defg-hij\",\n  \"type\": \"PRIVATE\",\n  \"fee\": 500\n}"
						},
						"url": {
							"raw": "{{apiUrl}}/events",
							"host": ["{{apiUrl}}"],
							"path": ["events"]
						},
						"description": "Requires authentication. Creates a paid private event."
					}
				},
				{
					"name": "Get All Events",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiUrl}}/events?page=1&limit=10&sortBy=createdAt&sortOrder=desc",
							"host": ["{{apiUrl}}"],
							"path": ["events"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" },
								{ "key": "sortBy", "value": "createdAt" },
								{ "key": "sortOrder", "value": "desc" }
							]
						},
						"description": "Public. Supports pagination, sorting, search and filters."
					}
				},
				{
					"name": "Get All Events (with search)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiUrl}}/events?searchTerm=tech&page=1&limit=10",
							"host": ["{{apiUrl}}"],
							"path": ["events"],
							"query": [
								{ "key": "searchTerm", "value": "tech" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						},
						"description": "Search events by title, description, or venue."
					}
				},
