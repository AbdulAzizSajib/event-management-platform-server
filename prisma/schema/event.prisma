model Event {
    id          String    @id @default(uuid())
    title       String
    description String
    date        DateTime
    time        String // e.g. "10:00 AM"
    venue       String? // Physical location (nullable if online)
    eventLink   String? // Online meeting link (nullable if physical)
    type        EventType @default(PUBLIC)
    fee         Decimal   @default(0) @db.Decimal(10, 2) // 0 = Free
    maxAttendees Int?     // null = unlimited
    image       String?   // Event banner/cover image URL
    isFeatured  Boolean   @default(false) // Admin selects for homepage hero

    categoryId String?
    category   Category? @relation(fields: [categoryId], references: [id])

    organizerId String
    organizer   User   @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    participants Participant[]
    payments     Payment[]
    invitations  Invitation[]
    reviews       Review[]
    savedBy       SavedEvent[]
    conversations Conversation[]

    @@map("events")
}
